#: bot/conversation_handlers.py:64 bot/conversation_handlers.py:144
#: bot/conversation_handlers.py:582
msgid "Start New Conversation"
msgstr "Начать новый диалог"

#: bot/conversation_handlers.py:67 bot/conversation_handlers.py:147
#: bot/conversation_handlers.py:585
msgid "Image Description"
msgstr "Описание изображения"

#: bot/conversation_handlers.py:70 bot/conversation_handlers.py:148
msgid "Chat History"
msgstr "История чата"

#: bot/conversation_handlers.py:74 bot/conversation_handlers.py:154
msgid ""
"Hi. It's Gemini Chat Bot. You can ask me anything and talk to me about "
"what you want"
msgstr ""
"Привет. Это чат-бот «Близнецы». Вы можете задать мне любой вопрос и "
"поговорить со мной о том, что вас интересует."

#: bot/conversation_handlers.py:149
msgid "Start Again"
msgstr "Начать заново"

#: bot/conversation_handlers.py:169
msgid "You asked for a conversation. OK, Let's start conversation!"
msgstr "Вы попросили начать разговор. Хорошо, давайте начнем!"

#: bot/conversation_handlers.py:173
msgid "You asked for a continue conversation. OK, Let's go!"
msgstr "Вы попросили продолжить разговор. Хорошо, поехали!"

#: bot/conversation_handlers.py:175
msgid "Return to menu"
msgstr "Вернуться в меню"

#: bot/conversation_handlers.py:191 bot/conversation_handlers.py:304
#: bot/conversation_handlers.py:343 bot/conversation_handlers.py:369
#: bot/conversation_handlers.py:397 bot/conversation_handlers.py:474
#: bot/conversation_handlers.py:545
msgid "Back to menu"
msgstr "Назад в меню"

#: bot/conversation_handlers.py:195 bot/conversation_handlers.py:471
msgid "Message is too long. Please shorten your message and try again."
msgstr "Сообщение слишком длинное. Пожалуйста, сократите свое сообщение и попробуйте еще раз."

#: bot/conversation_handlers.py:199 bot/conversation_handlers.py:400
#: bot/conversation_handlers.py:478
msgid "Wait for response processing..."
msgstr "Ожидайте обработку ответа..."

#: bot/conversation_handlers.py:216
msgid ""
"Sorry, I couldn't find the history for this conversation. Let's start a "
"new one."
msgstr "Извините, я не смог найти историю этой беседы. Давайте начнем новую."

#: bot/conversation_handlers.py:235
msgid "Save and Back to menu"
msgstr "Сохранить и вернуться в меню"

#: bot/conversation_handlers.py:240
msgid "Back to menu without saving"
msgstr "Вернуться в меню без сохранения"

#: bot/conversation_handlers.py:267 bot/conversation_handlers.py:427
#: bot/conversation_handlers.py:454 bot/conversation_handlers.py:511
msgid "You have exceeded your daily quota for requests. Please try again later."
msgstr "Вы превысили дневную квоту запросов. Пожалуйста, повторите попытку позже."

#: bot/conversation_handlers.py:269 bot/conversation_handlers.py:513
msgid "An error occurred while processing your message."
msgstr "Произошла ошибка при обработке вашего сообщения."

#: bot/conversation_handlers.py:288
msgid "Conversation not found."
msgstr "Разговор не найден."

#: bot/conversation_handlers.py:296
msgid "Continue Conversations"
msgstr "Продолжить диалоги"

#: bot/conversation_handlers.py:301
msgid "Delete Conversation"
msgstr "Удалить диалог"

#: bot/conversation_handlers.py:315
msgid "An error occurred while retrieving the conversation."
msgstr "Произошла ошибка при получении разговора."

#: bot/conversation_handlers.py:331
msgid "No conversation selected for deletion."
msgstr "Не выбран разговор для удаления."

#: bot/conversation_handlers.py:340
msgid "Could not delete the conversation. It may have been already deleted."
msgstr "Не удалось удалить разговор. Возможно, он уже был удален."

#: bot/conversation_handlers.py:347
msgid ""
"Conversation history deleted successfully. Back to menu Start new "
"Conversation"
msgstr "История диалогов успешно удалена. Назад в меню Начать новый диалог"

#: bot/conversation_handlers.py:355
msgid "An error occurred while deleting the conversation."
msgstr "Произошла ошибка при удалении разговора."

#: bot/conversation_handlers.py:373
msgid "You asked for Image description. OK, Send your image with caption!"
msgstr ""
"Вы попросили описание изображения. Хорошо, отправьте свое изображение с "
"подписью!"

#: bot/conversation_handlers.py:394
msgid "Image is too large. Please send an image smaller than 4MB."
msgstr "Изображение слишком большое. Пожалуйста, отправьте изображение размером менее 4 МБ."

#: bot/conversation_handlers.py:423
msgid "Empty response from Gemini"
msgstr "Пустой ответ от Gemini"

#: bot/conversation_handlers.py:429
msgid "Couldn't generate a response. Please try again."
msgstr "Не удалось сгенерировать ответ. Пожалуйста, попробуйте еще раз."

#: bot/conversation_handlers.py:456
msgid "An error occurred while processing the image."
msgstr "Произошла ошибка при обработке изображения."

#: bot/conversation_handlers.py:539
msgid "You have not any chat history"
msgstr "У вас нет истории чатов"

#: bot/conversation_handlers.py:557
msgid "An error occurred while retrieving the conversation history."
msgstr "Произошла ошибка при получении истории разговоров."

#: bot/conversation_handlers.py:586
msgid "Refresh"
msgstr "Обновить"

#: bot/conversation_handlers.py:590
msgid "Until next time!"
msgstr "До скорого!"


# Task-related translations
msgid "📅 Tasks"
msgstr "📅 Задачи"

msgid "➕ Add New Task"
msgstr "➕ Добавить задачу"

msgid "📋 List Tasks"
msgstr "📋 Список задач"

msgid "🔙 Back to Menu"
msgstr "🔙 Назад в меню"

msgid "📅 *Tasks Menu*\n\nManage your scheduled tasks here. You can add new tasks, view existing ones, or delete them."
msgstr "📅 *Меню задач*\n\nУправляйте своими запланированными задачами здесь. Вы можете добавлять новые задачи, просматривать существующие или удалять их."

msgid "📝 *Add New Task*\n\nPlease enter the prompt you want to send to Gemini:"
msgstr "📝 *Добавить новую задачу*\n\nПожалуйста, введите запрос, который вы хотите отправить Gemini:"

msgid "Cancel"
msgstr "Отмена"

msgid "Prompt is too long. Please keep it under 1000 characters."
msgstr "Запрос слишком длинный. Пожалуйста, сократите его до 1000 символов."

msgid "⏰ *Set Execution Time*\n\nPlease enter the time when you want this task to run (format: HH:MM, e.g., 09:30 or 14:00):"
msgstr "⏰ *Установить время выполнения*\n\nПожалуйста, введите время, когда вы хотите запустить эту задачу (формат: ЧЧ:ММ, например, 09:30 или 14:00):"

msgid "Invalid time format. Please use HH:MM format (e.g., 09:30 or 14:00):"
msgstr "Неверный формат времени. Пожалуйста, используйте формат ЧЧ:ММ (например, 09:30 или 14:00):"

msgid "🔄 *Set Interval*\n\nHow often should this task run?"
msgstr "🔄 *Установить интервал*\n\nКак часто должна выполняться эта задача?"

msgid "Once"
msgstr "Один раз"

msgid "Daily"
msgstr "Ежедневно"

msgid "Weekly"
msgstr "Еженедельно"

msgid "once"
msgstr "один раз"

msgid "daily"
msgstr "ежедневно"

msgid "weekly (every Monday)"
msgstr "еженедельно (каждый понедельник)"

msgid "weekly"
msgstr "еженедельно"

msgid "✅ *Task Created Successfully!*\n\n*Prompt:* {prompt}\n*Time:* {run_time}\n*Interval:* {interval_text}"
msgstr "✅ *Задача успешно создана!*\n\n*Запрос:* {prompt}\n*Время:* {run_time}\n*Интервал:* {interval_text}"

msgid "❌ Error creating task. Please try again."
msgstr "❌ Ошибка создания задачи. Пожалуйста, попробуйте еще раз."

msgid "📋 View Tasks"
msgstr "📋 Просмотр задач"

msgid "📋 *Your Tasks*\n\nYou don't have any scheduled tasks yet."
msgstr "📋 *Ваши задачи*\n\nУ вас пока нет запланированных задач."

msgid "➕ Add Task"
msgstr "➕ Добавить задачу"

msgid "🔙 Back"
msgstr "🔙 Назад"

msgid "📋 *Your Scheduled Tasks*\n\n"
msgstr "📋 *Ваши запланированные задачи*\n\n"

msgid "🗑️ Delete Task #{task['id']}"
msgstr "🗑️ Удалить задачу #{task['id']}"

msgid "❌ Error retrieving tasks. Please try again."
msgstr "❌ Ошибка получения задач. Пожалуйста, попробуйте еще раз."

msgid "✅ Task deleted successfully!"
msgstr "✅ Задача успешно удалена!"

msgid "❌ Task not found or already deleted."
msgstr "❌ Задача не найдена или уже удалена."

msgid "❌ Error deleting task."
msgstr "❌ Ошибка удаления задачи."

msgid "🔔 *Scheduled Task Result*\n\n*Prompt:* {prompt}\n\n*Response:*\n{response}"
msgstr "🔔 *Результат запланированной задачи*\n\n*Запрос:* {prompt}\n\n*Ответ:*\n{response}"

msgid "❌ Error executing scheduled task. Please try again later."
msgstr "❌ Ошибка выполнения запланированной задачи. Пожалуйста, попробуйте позже."

msgid "Tasks Menu"
msgstr "Меню задач"
