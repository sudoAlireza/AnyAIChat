# Required
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
GEMINI_API_TOKEN=your_gemini_api_key

# Bot settings
GEMINI_MODEL=gemini-1.5-flash
LANGUAGE=en
LOG_LEVEL=INFO

# Access control (set at least one)
AUTHORIZED_USER=123456789          # Comma-separated Telegram user IDs
ALLOW_ALL_USERS=false              # Set to true to allow all users

# Security
ENCRYPTION_KEY=                    # Fernet key for API key encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
SAFETY_OVERRIDE=                   # Set to BLOCK_NONE to disable safety filters

# Rate limiting
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_HOUR=200

# Performance
GEMINI_MAX_WORKERS=20
MAX_HISTORY_MESSAGES=100
DATABASE_PATH=data/gemini_bot.db

# Limits
MAX_MESSAGE_LENGTH=4000
ITEMS_PER_PAGE=10
CONVERSATION_WARNING_THRESHOLD=500
CONVERSATION_AUTO_RESET_THRESHOLD=750

# Scheduler
REMINDER_CHECK_INTERVAL_MINUTES=1
TEMP_FILE_MAX_AGE_HOURS=1
